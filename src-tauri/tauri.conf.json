{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Keycast Windows",
    "version": "0.1.0",
    "identifier": "com.shenjianz.keycastwindows",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Keycast Windows",
                "label": "main",
                "width": 750,
                "height": 500,
                "minWidth": 700,
                "minHeight": 400,
                "visible": false,
                "center": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "__KEYCAST_WINDOWS_TAURI_UPDATER_PUBLIC_KEY__",
            "endpoints": [
                "https://github.com/shenjianZ/keycast-windows/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
